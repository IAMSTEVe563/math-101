<button onclick="launchCloaked()">Launch Stealth Proxy</button>

<script>
function launchCloaked() {
    // 1. Get the target URL from an input or variable
    const url = document.getElementById('url-input').value; 
    
    // 2. Open a new 'about:blank' tab
    const win = window.open('about:blank', '_blank');
    if (!win) return alert("Please allow pop-ups to use stealth mode.");

    // 3. Create the iframe element
    const iframe = win.document.createElement('iframe');
    
    // 4. Style it to be full-screen and borderless
    iframe.style.position = "fixed";
    iframe.style.top = "0";
    iframe.style.left = "0";
    iframe.style.width = "100vw";
    iframe.style.height = "100vh";
    iframe.style.border = "none";
    iframe.style.zIndex = "999999";
    
    // 5. Set the iframe source to your proxy URL
    // (Ensure this matches your Ultraviolet config prefix)
    iframe.src = window.location.origin + '/service/' + btoa(url); 

    // 6. Inject the iframe into the new tab
    win.document.body.appendChild(iframe);
    win.document.body.style.margin = "0";
    win.document.body.style.padding = "0";
}
</script>
